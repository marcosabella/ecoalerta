{
  "appId": "com.ecoalerta.recoleccion",
  "appName": "EcoAlerta",
  "webDir": "dist",
  "android": {
    "adjustMarginsForEdgeToEdge": "force"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#102F23",
      "overlaysWebView": false
    },
    "PushNotifications": {
      "presentationOptions": ["alert", "sound"]
    }
  },
  "server": {
    "androidScheme": "https"
  }
}
